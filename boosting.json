#!/bin/bash

# ================================================
#  Auto Install Apps - Termux Script
#  Apps: ZArchiver, MT Manager, Rotation Control
# ================================================

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}   Auto Tải & Cài App - Termux Script   ${NC}"
echo -e "${YELLOW}========================================${NC}"
echo ""

# Xin quyền truy cập storage
echo -e "${YELLOW}[*] Xin quyền truy cập bộ nhớ...${NC}"
termux-setup-storage
sleep 2

# Cài wget nếu chưa có
echo -e "${YELLOW}[*] Kiểm tra wget...${NC}"
pkg install wget -y > /dev/null 2>&1

# Thư mục lưu APK
DOWNLOAD_DIR="$HOME/storage/downloads/AutoInstall"
mkdir -p "$DOWNLOAD_DIR"

# Danh sách app
declare -A APPS
APPS["ZArchiver"]="https://d.apkpure.com/b/APK/ru.zdevs.zarchiver?version=latest"
APPS["MT_Manager"]="https://d.apkpure.com/b/APK/bin.mt.plus?version=latest"
APPS["Rotation_Control"]="https://d.apkpure.com/b/APK/ahapps.controlthescreenorientation?version=latest"

# Tải từng app
for APP_NAME in "${!APPS[@]}"; do
    URL="${APPS[$APP_NAME]}"
    APK_PATH="$DOWNLOAD_DIR/${APP_NAME}.apk"

    echo ""
    echo -e "${YELLOW}[↓] Đang tải: ${APP_NAME}...${NC}"

    wget --user-agent="Mozilla/5.0 (Android 13; Mobile)" \
         -L -O "$APK_PATH" "$URL" \
         --show-progress 2>&1

    if [ -f "$APK_PATH" ] && [ -s "$APK_PATH" ]; then
        echo -e "${GREEN}[✓] Tải xong: ${APP_NAME}${NC}"
    else
        echo -e "${RED}[✗] Lỗi tải: ${APP_NAME}${NC}"
        continue
    fi
done

echo ""
echo -e "${YELLOW}========================================${NC}"
echo -e "${GREEN}[✓] Tải xong tất cả! Đang mở cài đặt...${NC}"
echo -e "${YELLOW}========================================${NC}"
echo ""

# Cài từng APK
for APP_NAME in "${!APPS[@]}"; do
    APK_PATH="$DOWNLOAD_DIR/${APP_NAME}.apk"

    if [ -f "$APK_PATH" ] && [ -s "$APK_PATH" ]; then
        echo -e "${YELLOW}[*] Đang cài: ${APP_NAME}...${NC}"
        termux-open "$APK_PATH"
        echo -e "${GREEN}    → Bấm 'Cài đặt' trên màn hình rồi quay lại terminal${NC}"
        echo "    Nhấn ENTER để tiếp tục cài app tiếp theo..."
        read
    fi
done

echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}   Hoàn tất! Đã cài xong tất cả app.   ${NC}"
echo -e "${GREEN}========================================${NC}"
